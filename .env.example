# Qdrant Local Configuration (Docker)
# Start Qdrant with: docker compose up -d

# Your local Qdrant instance
QDRANT_URL=http://localhost:6333

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Contextual AI Configuration (for Part 5)
# Get your API key from: https://app.contextual.ai
CONTEXTUAL_API_KEY=your-contextual-api-key-here
